{
  "name": "kalebtec-icon-brief",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:plugin": "npm run build && node scripts/sync-plugin-builder.mjs",
    "render:characters": "vite-node --config scripts/vite-character-sheet.config.ts scripts/render-character-sheet.tsx",
    "test:web": "vitest run",
    "check": "npm run test:web && npm run build:plugin"
  },
  "dependencies": {
    "solid-js": "1.9.14"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-singlefile": "2.3.3",
    "vite-plugin-solid": "2.11.12",
    "vitest": "3.2.7"
  }
}
